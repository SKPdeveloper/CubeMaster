rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Приватні дані користувача
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Публічний каталог матеріалів — тільки читання для клієнтів
    match /materialCatalog/{sku} {
      allow read: if request.auth != null;
      allow write: if false; // тільки через Cloud Functions (service account)
    }

    // Публічні ціни — тільки читання
    match /priceEntries/{entryId} {
      allow read: if request.auth != null;
      allow write: if false; // тільки Cloud Functions
    }
  }
}
